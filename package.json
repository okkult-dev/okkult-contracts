    "hardhat":          "^2.22.0",
    "solidity-coverage": "^0.8.0",
    "solhint":           "^4.0.0",
    "dotenv":            "^16.0.0",
    "typescript":        "^5.4.0",
    "ts-node":           "^10.9.0",
    "@types/node":       "^20.0.0",
    "chai":              "^4.3.0",
    "ethers":            "^6.13.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
