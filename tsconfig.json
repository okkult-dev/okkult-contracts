{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "moduleResolution": "node",
    "lib":              ["ES2020"],
    "outDir":           "./dist",
    "rootDir":          "./",
    "strict":           true,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "declaration":      true,
    "skipLibCheck":     true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./hardhat.config.ts",
    "./scripts/**/*.ts",
    "./test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "artifacts",
    "cache",
    "dist"
  ]
}
